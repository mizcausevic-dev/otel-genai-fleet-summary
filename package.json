{
  "name": "otel-genai-fleet-summary",
  "version": "0.1.0",
  "description": "Fleet-summary for OTel GenAI OTLP span exports. Walks a directory of OTLP JSON files, surfaces governance findings: missing provider/model attrs, unauthorized model usage (whitelist), high error rates, missing cost annotations, token-volume outliers, missing operation names. Closes the fleet-summary quintet alongside agent-card / mcp-tool-card / prompt-provenance / evidence-bundle.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/otel-genai-fleet-summary"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "genai",
    "fleet",
    "governance",
    "audit",
    "ai-governance",
    "kinetic-gain-suite",
    "typescript"
  ],
  "bin": {
    "otel-genai-fleet-summary": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/traces --format markdown",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
